<view class="page">
  <view class="filters card">
    <picker mode="date" fields="month" value="{{month}}" bindchange="onMonthChange">
      <view class="picker">{{labels.month}}：{{month}}</view>
    </picker>
    <picker range="{{businessTypes}}" range-key="label" value="{{businessIndex}}" bindchange="onBusinessChange">
      <view class="picker">{{labels.type}}：{{businessTypes[businessIndex].label}}</view>
    </picker>
  </view>

  <view wx:for="{{transactions}}" wx:key="id" class="card row">
    <view class="row-main">
      <view class="row-title">{{item.displayTitle}}</view>
      <text class="muted">{{item.transaction_date}} {{item.displayAccount}}</text>
      <text wx:if="{{item.displayMaterial}}" class="muted">{{item.displayMaterial}}</text>
      <text wx:if="{{item.remark}}" class="muted">{{item.remark}}</text>
    </view>
    <view class="{{item.business_type === 'sale' ? 'amount-income' : 'amount-expense'}}">
      {{item.amountSign}}¥{{item.amount}}
    </view>
  </view>
  <view wx:if="{{!transactions.length}}" class="card muted">{{labels.noData}}</view>
</view>
