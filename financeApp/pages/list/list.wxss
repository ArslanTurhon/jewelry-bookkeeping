.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.row-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.row > view:last-child {
  font-size: 34rpx;
  font-weight: 700;
}

.row-title {
  font-weight: 700;
}

.filters {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
