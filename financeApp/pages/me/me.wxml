<view class="page">
  <view class="card">
    <view class="name">{{user.name || labels.user}}</view>
    <text class="muted">{{labels.title}}</text>
    <button class="primary" bindtap="relogin">{{labels.relogin}}</button>
  </view>

  <view class="card">
    <view class="section-title">{{labels.language}}</view>
    <picker range="{{languages}}" range-key="name" bindchange="onLanguageChange">
      <view class="picker">{{labels.currentLanguage}}：{{language}}</view>
    </picker>
  </view>

  <view class="card">
    <view class="section-title">{{labels.opening}}</view>
    <view wx:for="{{balanceFields}}" wx:key="key" class="balance-field">
      <text>{{item.label}}</text>
      <input type="digit" value="{{item.value}}" data-key="{{item.key}}" bindinput="onBalanceInput" />
    </view>
    <button class="primary" bindtap="saveOpening">{{labels.save}}</button>
  </view>
</view>
