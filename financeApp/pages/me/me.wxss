.name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.section-title {
  font-weight: 700;
  margin-bottom: 18rpx;
}

.balance-field {
  display: grid;
  grid-template-columns: 220rpx 1fr;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.balance-field text {
  color: #3b4658;
  font-size: 26rpx;
}
