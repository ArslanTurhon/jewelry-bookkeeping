.hero {
  background: #14213d;
  color: #fff;
}

.balance {
  font-size: 58rpx;
  font-weight: 700;
  margin: 18rpx 0 8rpx;
}

.summary,
.money-grid,
.stock-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.summary .card {
  margin-bottom: 24rpx;
}

.summary view view {
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 12rpx;
}

.section-title {
  font-weight: 700;
  margin-bottom: 18rpx;
}

.category-stat {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf1f7;
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
}

.chip {
  background: #fff;
  border: 1rpx solid #d7deea;
  border-radius: 999rpx;
  padding: 14rpx 22rpx;
}

.money-grid {
  margin-top: 22rpx;
}

.money-grid view,
.stock-grid view {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 10rpx;
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stock-grid view {
  background: #f6f8fc;
}
